{
  "uid": "efr6oe64zqbk0c",
  "title": "Taskmaster ECS Monitoring",
  "tags": ["taskmaster", "ecs"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "cfr785so0pa80f"},
        "expr": "jvm_memory_used_bytes{area=\"heap\"}",
        "legendFormat": "Heap Used"
      }]
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/sec)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "cfr785so0pa80f"},
        "expr": "rate(http_server_requests_seconds_count[1m])",
        "legendFormat": "{{method}} {{uri}}"
      }]
    },
    {
      "id": 3,
      "title": "HTTP Request Latency P95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "cfr785so0pa80f"},
        "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket[5m]))",
        "legendFormat": "P95 Latency"
      }]
    },
    {
      "id": 4,
      "title": "ECS CPU Utilization %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "dfr785s213gn4d"},
        "dimensions": {
          "ClusterName": "taskmaster-dev-cluster",
          "ServiceName": "taskmaster-dev-service"
        },
        "matchExact": true,
        "metricName": "CPUUtilization",
        "namespace": "AWS/ECS",
        "period": "60",
        "refId": "A",
        "region": "ap-south-1",
        "statistics": ["Average"]
      }]
    },
    {
      "id": 5,
      "title": "ECS Memory Utilization %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "dfr785s213gn4d"},
        "dimensions": {
          "ClusterName": "taskmaster-dev-cluster",
          "ServiceName": "taskmaster-dev-service"
        },
        "matchExact": true,
        "metricName": "MemoryUtilization",
        "namespace": "AWS/ECS",
        "period": "60",
        "refId": "A",
        "region": "ap-south-1",
        "statistics": ["Average"]
      }]
    }
  ]
}
